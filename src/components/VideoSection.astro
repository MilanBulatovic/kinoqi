---
interface Props {
  url: string;
  caption?: string;
}

const { url, caption } = Astro.props;

function embedUrl(url: string): { src: string; type: "iframe" | "video"; platform?: "youtube" | "vimeo" } | null {
  try {
    const u = new URL(url);
    if (u.hostname.includes("youtube.com")) {
      const id = u.searchParams.get("v");
      return id ? { src: `https://www.youtube.com/embed/${id}?enablejsapi=1`, type: "iframe", platform: "youtube" } : null;
    }
    if (u.hostname.includes("youtu.be")) {
      const id = u.pathname.slice(1);
      return id ? { src: `https://www.youtube.com/embed/${id}?enablejsapi=1`, type: "iframe", platform: "youtube" } : null;
    }
    if (u.hostname.includes("vimeo.com")) {
      const id = u.pathname.slice(1);
      return id ? { src: `https://player.vimeo.com/video/${id}?api=1`, type: "iframe", platform: "vimeo" } : null;
    }
    return { src: url, type: "video" };
  } catch {
    return null;
  }
}

const embed = embedUrl(url);
---

{embed && (
  <figure class="section video-section">
    {embed.type === "iframe" ? (
      <div class="video-embed">
        <iframe
          src={embed.src}
          title={caption ?? "Video"}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          data-scroll-video
          data-platform={embed.platform}
        />
      </div>
    ) : (
      <video controls class="video-direct" preload="metadata" data-scroll-video>
        <source src={embed.src} />
        Tvoj browser ne podržava video.
      </video>
    )}
    {caption && <figcaption>{caption}</figcaption>}
  </figure>
)}

<style>
  .section { margin: 0; }

  .video-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #000;
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-direct {
    width: 100%;
    border-radius: 0.75rem;
    display: block;
    background: #000;
  }

  .video-section figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #6b7280;
    text-align: center;
  }
</style>
