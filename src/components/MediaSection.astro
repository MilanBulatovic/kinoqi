---
import { galleryImageSrc } from "@/lib/galleryImageUrl";
import VideoSection from "./VideoSection.astro";
import GallerySection from "./GallerySection.astro";
import AnimationTextSection from "./AnimationTextSection.astro";
import FullWidthBanner from "./FullWidthBanner.astro";
import FormSection from "./FormSection.astro";

type VideoSectionType = {
  _key: string;
  _type: "videoSection";
  url: string;
  caption?: string;
};

type GallerySectionType = {
  _key: string;
  _type: "gallerySection";
  images?: Array<{
    _key: string;
    src?: string | null;
    asset?: { url?: string } | null;
    alt?: string;
    caption?: string;
  }>;
};

type AnimationTextSectionType = {
  _key: string;
  _type: "animationTextSection";
  content?: Array<{
    _type: string;
    _key: string;
    style?: string;
    children?: Array<{ text: string; _type: string; marks?: string[] }>;
  }>;
};

type FullWidthTextSectionType = {
  _key: string;
  _type: "fullWidthTextSection";
  backgroundImage?: { asset: { url: string }; hotspot?: { x: number; y: number } };
  text?: string;
};

type FormSectionType = {
  _key: string;
  _type: "formSection";
  heading?: string;
  nameLabel?: string;
  emailLabel?: string;
  messageLabel?: string;
  submitLabel?: string;
  actionUrl?: string;
};

interface Props {
  sections?: Array<
    | VideoSectionType
    | GallerySectionType
    | AnimationTextSectionType
    | FullWidthTextSectionType
    | FormSectionType
  >;
}

const { sections } = Astro.props;
---

{sections && sections.length > 0 && (
  <div class="sections">
    {sections.map((section) => {
      if (section._type === "videoSection") {
        return <VideoSection url={section.url} caption={section.caption} />;
      }

      if (section._type === "gallerySection" && section.images?.length) {
        const galleryImages = section.images.filter((img) => galleryImageSrc(img));
        if (galleryImages.length > 0) {
          return <GallerySection images={galleryImages} instanceId={section._key} />;
        }
      }

      if (section._type === "animationTextSection" && section.content && section.content.length > 0) {
        return <AnimationTextSection content={section.content} />;
      }

      if (section._type === "fullWidthTextSection" && section.backgroundImage?.asset) {
        return <FullWidthBanner backgroundImage={section.backgroundImage} text={section.text} />;
      }

      if (section._type === "formSection") {
        return (
          <FormSection
            instanceId={section._key}
            heading={section.heading}
            nameLabel={section.nameLabel}
            emailLabel={section.emailLabel}
            messageLabel={section.messageLabel}
            submitLabel={section.submitLabel}
            actionUrl={section.actionUrl}
          />
        );
      }

      return null;
    })}
  </div>
)}

<style>
  .sections {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 3rem;
  }
</style>
