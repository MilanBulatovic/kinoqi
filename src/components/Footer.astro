---
import { sanityClient } from "@/sanity/client";
import LottiePlayer from "@/components/LottiePlayer.astro";
import FooterMenuTree from "@/components/FooterMenuTree.astro";
import { MAIN_MENU_ID, mainMenuGROQ } from "@/sanity/navigationQuery";
import type { MainMenuItem } from "@/sanity/menuTypes";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const showLottie = currentPath === "/";

const menuDoc = await sanityClient.fetch<{ items: MainMenuItem[] } | null>(mainMenuGROQ, {
  menuId: MAIN_MENU_ID,
});
const menuItems = menuDoc?.items ?? [];
---

<footer id="site-footer" class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand footer-anim">
        <a href="/" class="footer-logo">Kinoqi</a>
        <p>Sadržaj.</p>
      </div>

      {
        menuItems.length > 0 && (
          <nav class="footer-nav footer-anim">
            <h3>Navigacija</h3>
            <FooterMenuTree items={menuItems} />
          </nav>
        )
      }
    </div>

    <div class="footer-bottom footer-anim">
      <p>&copy; {new Date().getFullYear()} Kinoqi. Sva prava zadržana.</p>
    </div>
  </div>

  {
    showLottie && (
      <div class="footer-lottie-deco" aria-hidden="true">
        <LottiePlayer
          src="/Rocket Lunch.lottie"
          width="7.5rem"
          height="7.5rem"
          loop={true}
          autoplay={true}
          class="footer-lottie-deco__player"
        />
      </div>
    )
  }
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-dark);
    color: #9ca3af;
    margin-top: auto;
  }

  .footer-lottie-deco {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 1;
    width: 7.5rem;
    height: 7.5rem;
    pointer-events: none;
  }

  .footer-lottie-deco :global(.lottie-player) {
    max-width: 100%;
    max-height: 100%;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    padding: 3rem 0 2rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo {
    font-family: "Kablammo", serif;
    font-size: 1.6rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.03em;
    background: var(--logo-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .footer-nav h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  /* FooterMenuTree = drugi Astro scope — stil kroz :global, u suprotnom vidi se disk liste. */
  .footer-nav :global(ul.footer-menu-list) {
    list-style: none;
    list-style-type: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav :global(ul.footer-menu-list li) {
    list-style: none;
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  .footer-nav :global(ul.footer-menu-list--nested) {
    margin-top: 0.4rem;
    margin-left: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    gap: 0.4rem;
  }

  .footer-nav :global(a) {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.5;
    font-weight: 500;
    font-family: inherit;
    display: inline-block;
    letter-spacing: 0.01em;
    transition: color 0.15s, opacity 0.15s;
  }

  .footer-nav :global(a:hover) {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid #1f2937;
    padding: 1.25rem 0;
    font-size: 0.8rem;
    color: #4b5563;
  }
</style>
