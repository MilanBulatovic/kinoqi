---
import { sanityClient } from "@/sanity/client";

const menuItems = await sanityClient.fetch<
  Array<{
    _id: string;
    title: string;
    url?: string;
    pageRef?: { slug: { current: string } };
  }>
>(
  `*[_type == "menu"] | order(order asc) {
    _id,
    title,
    url,
    pageRef->{ slug }
  }`
);

function resolveUrl(item: { url?: string; pageRef?: { slug: { current: string } } }) {
  if (item.pageRef?.slug?.current) {
    return `/stranice/${item.pageRef.slug.current}`;
  }
  return item.url ?? "#";
}
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Kinoqi</a>
        <p>Sadržaj.</p>
      </div>

      {
        menuItems.length > 0 && (
          <nav class="footer-nav">
            <h3>Navigacija</h3>
            <ul>
              {menuItems.map((item) => (
                <li>
                  <a href={resolveUrl(item)}>{item.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Kinoqi. Sva prava zadržana.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #111827;
    color: #9ca3af;
    margin-top: auto;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    padding: 3rem 0 2rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: #6b7280;
  }

  .footer-nav h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid #1f2937;
    padding: 1.25rem 0;
    font-size: 0.8rem;
    color: #4b5563;
  }
</style>
