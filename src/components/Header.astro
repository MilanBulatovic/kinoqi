---
import { sanityClient } from "@/sanity/client";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const menuItems = await sanityClient.fetch<
  Array<{
    _id: string;
    title: string;
    url?: string;
    pageRef?: { slug: { current: string } };
    openInNewTab: boolean;
  }>
>(
  `*[_type == "menu"] | order(order asc) {
    _id,
    title,
    url,
    pageRef->{ slug },
    openInNewTab
  }`
);

function resolveUrl(item: { url?: string; pageRef?: { slug: { current: string } } }) {
  if (item.pageRef?.slug?.current) {
    return `/stranice/${item.pageRef.slug.current}`;
  }
  return item.url ?? "#";
}
---

<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo" aria-label="Sanity | Astro">Sanity | Astro</a>

    {
      menuItems.length > 0 && (
        <nav>
          {menuItems.map((item) => {
            const href = resolveUrl(item);
            return (
              <a
                href={href}
                class:list={["nav-link", { active: currentPath === href }]}
                target={item.openInNewTab ? "_blank" : undefined}
                rel={item.openInNewTab ? "noopener noreferrer" : undefined}
              >
                {item.title}
              </a>
            );
          })}
        </nav>
      )
    }
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    font-size: 1.5rem;
    font-weight: 800;
    color: #242424;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    color: #374151;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.15s;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: #4f46e5;
    transition: width 0.2s ease;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #4f46e5;
  }
</style>
