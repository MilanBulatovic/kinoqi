---
import { sanityClient } from "@/sanity/client";
import HeaderSubNav from "@/components/HeaderSubNav.astro";
import { MAIN_MENU_ID, mainMenuGROQ } from "@/sanity/navigationQuery";
import type { MainMenuItem } from "@/sanity/menuTypes";
import { resolveMenuItemUrl } from "@/sanity/resolveMenuUrl";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const isHome = currentPath === "/";

const menuDoc = await sanityClient.fetch<{ items: MainMenuItem[] } | null>(mainMenuGROQ, {
  menuId: MAIN_MENU_ID,
});
const menuItems = menuDoc?.items ?? [];
---

<header class:list={["site-header", { "site-header--solid": !isHome }]} data-header-root>
  <div class="container">
    <a href="/" class="site-logo" aria-label="Kinoqi" data-astro-reload>kinoqi</a>

    {
      menuItems.length > 0 && (
        <>
          <button
            type="button"
            class="nav-toggle"
            id="nav-toggle"
            aria-label="Meni"
            aria-expanded="false"
            aria-controls="main-nav"
          >
            <svg class="nav-toggle__svg" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
              <line class="nav-toggle__line nav-toggle__line--top" x1="4" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <line class="nav-toggle__line nav-toggle__line--mid" x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <line class="nav-toggle__line nav-toggle__line--bot" x1="4" y1="17" x2="20" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
          <div class="nav-backdrop" id="nav-backdrop" aria-hidden="true"></div>
          <nav id="main-nav" class="main-nav">
            <span class="nav-pill" id="nav-pill" aria-hidden="true"></span>
            {menuItems.map((item) => {
              const href = resolveMenuItemUrl(item, "header");
              const sub = item.children?.filter(Boolean) ?? [];
              if (sub.length > 0) {
                return (
                  <div class="nav-item nav-item--has-children">
                    <a
                      href={href}
                      class:list={["nav-link", "nav-link--parent", { active: currentPath === href }]}
                      data-pill-link
                      aria-haspopup="true"
                      target={item.openInNewTab ? "_blank" : undefined}
                      rel={item.openInNewTab ? "noopener noreferrer" : undefined}
                      data-astro-reload={href === "/" ? true : undefined}
                    >
                      <span class="nav-link__label">{item.title}</span>
                      <span class="nav-link__caret" aria-hidden="true">
                        <svg
                          class="nav-link__caret-icon"
                          width="10"
                          height="6"
                          viewBox="0 0 10 6"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path
                            d="M1 1.5L5 4.5L9 1.5"
                            stroke="currentColor"
                            stroke-width="1.4"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </span>
                    </a>
                    <HeaderSubNav items={sub} depth={1} />
                  </div>
                );
              }
              return (
                <div class="nav-item">
                  <a
                    href={href}
                    class:list={["nav-link", { active: currentPath === href }]}
                    data-pill-link
                    target={item.openInNewTab ? "_blank" : undefined}
                    rel={item.openInNewTab ? "noopener noreferrer" : undefined}
                    data-astro-reload={href === "/" ? true : undefined}
                  >
                    {item.title}
                  </a>
                </div>
              );
            })}
          </nav>
        </>
      )
    }
  </div>
</header>

<style>
  .site-header {
    background: transparent;
    border-bottom: none;
    padding: 1.25rem 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .site-header--solid {
    background: var(--color-dark);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-logo {
    font-family: "Kablammo", serif;
    font-size: 1.6rem;
    font-weight: 400;
    text-decoration: none;
    letter-spacing: 0.03em;
    background: var(--logo-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    position: relative;
  }

  .nav-item {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  /* Child komponenta (HeaderSubNav) = drugačiji Astro scope — :global na njene klase. */
  #main-nav :global(.nav-sub) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #main-nav :global(.nav-sub__row) {
    position: relative;
  }

  @media (min-width: 768px) {
    /* Prazan prostor ispod "roditelja" = hover ostaje aktivan do padajućeg dela. */
    .nav-item--has-children::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      height: 0.4rem;
      z-index: 199;
    }

    /* Isti stil „prstena” kao .nav-pill::before (gradijent) + mali staklasti fill */
    .nav-item--has-children > :global(ul.nav-sub),
    :global(.nav-sub__row) > :global(ul.nav-sub) {
      border: none;
      border-radius: 10px;
      padding: 0.4rem 0;
      background: rgba(5, 20, 36, 0.88);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
      box-shadow: 0 10px 32px rgba(0, 0, 0, 0.45);
      isolation: isolate;
    }

    .nav-item--has-children > :global(ul.nav-sub)::before,
    :global(.nav-sub__row) > :global(ul.nav-sub)::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: 10px;
      padding: 1px;
      background: var(--logo-gradient);
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      mask-composite: exclude;
      pointer-events: none;
      z-index: 0;
    }

    .nav-item--has-children > :global(ul.nav-sub) {
      display: none;
      position: absolute;
      top: calc(100% + 0.35rem);
      left: 0;
      min-width: 10.5rem;
      z-index: 200;
    }

    .nav-item--has-children:hover > :global(ul.nav-sub),
    .nav-item--has-children:focus-within > :global(ul.nav-sub) {
      display: block;
    }

    :global(.nav-sub__row) > :global(ul.nav-sub) {
      display: none;
      position: absolute;
      top: 0;
      left: calc(100% + 0.2rem);
      min-width: 9.5rem;
      z-index: 201;
    }

    :global(.nav-sub__row):hover > :global(ul.nav-sub),
    :global(.nav-sub__row):focus-within > :global(ul.nav-sub) {
      display: block;
    }

    #main-nav :global(a.nav-link--sub),
    #main-nav :global(a.nav-link--sub:visited) {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      text-align: left;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      padding: 0.4rem 0.9rem;
      border-radius: 6px;
      color: rgba(255, 255, 255, 0.85);
    }

    #main-nav :global(a.nav-link--sub:hover),
    #main-nav :global(a.nav-link--sub:focus-visible) {
      color: #fff;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.06);
    }

    #main-nav :global(a.nav-link--deeper) {
      text-decoration: none;
      font-size: 0.82rem;
    }
  }

  .nav-pill {
    position: absolute;
    top: 50%;
    left: 0;
    height: 32px;
    border-radius: 999px;
    pointer-events: none;
    transform: translateY(-50%);
    opacity: 0;
    backdrop-filter: blur(6px);
    background: rgba(255, 255, 255, 0.07);
  }

  .nav-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 999px;
    padding: 1px;
    background: var(--logo-gradient);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    position: relative;
    z-index: 1;
    transition: color 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #fff;
  }

  .nav-link--parent {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
  }

  .nav-link__label {
    min-width: 0;
  }

  .nav-link__caret {
    display: inline-flex;
    flex-shrink: 0;
    margin-top: 0.08em;
    color: currentColor;
    opacity: 0.78;
    transition: transform 0.22s ease, opacity 0.15s ease;
  }

  @media (min-width: 768px) {
    .nav-item--has-children:hover .nav-link__caret,
    .nav-item--has-children:focus-within .nav-link__caret {
      transform: rotate(180deg);
      opacity: 1;
    }
  }

  /* ── Mobile trigger ─────────────────────────────────────── */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    cursor: pointer;
    z-index: 160;
    transition: background 0.2s;
  }

  .nav-toggle:hover {
    background: rgba(255, 255, 255, 0.14);
  }

  .nav-toggle:focus-visible {
    outline: 2px solid rgba(232, 201, 154, 0.7);
    outline-offset: 2px;
  }

  .nav-toggle__svg {
    display: block;
  }

  .nav-backdrop {
    display: none;
  }

  @media (max-width: 767px) {
    .nav-toggle {
      display: flex;
    }

    .nav-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 140;
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(4px);
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
    }

    .site-header.nav-open .nav-backdrop {
      pointer-events: auto;
    }

    .main-nav {
      position: fixed;
      inset: 0;
      z-index: 150;
      flex-direction: column;
      justify-content: center;
      align-items: stretch;
      gap: 0.35rem;
      padding: 5rem 1.75rem 2rem;
      max-width: none;
      margin: 0;
      background: linear-gradient(165deg, rgba(5, 20, 36, 0.97) 0%, rgba(10, 6, 30, 0.96) 100%);
      backdrop-filter: blur(14px);
      pointer-events: none;
      visibility: hidden;
    }

    /* Klik mora da stigne do <a> — inače CSS pointer-events: none na navu blokira sve */
    .site-header.nav-open .main-nav {
      pointer-events: auto;
    }

    .nav-pill {
      display: none;
    }

    .nav-item {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .nav-item--has-children :global(ul.nav-sub),
    :global(.nav-sub__row) :global(ul.nav-sub) {
      display: block;
      position: static;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      min-width: 0;
      margin-top: 0.2rem;
      margin-left: 0.4rem;
      padding: 0 0 0.2rem 0.55rem;
      border-left: 1px solid rgba(255, 255, 255, 0.12);
      background: transparent;
      border-radius: 0;
      box-shadow: none;
    }

    .nav-link {
      font-size: 1.35rem;
      padding: 0.85rem 1rem;
      text-align: center;
      border-radius: 12px;
      background: transparent;
    }

    #main-nav :global(a.nav-link--sub),
    #main-nav :global(a.nav-link--deeper) {
      text-align: left;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 500;
      padding: 0.5rem 0.75rem 0.5rem 1.1rem;
    }

    #main-nav :global(a.nav-link--deeper) {
      font-size: 1rem;
      padding-left: 1.5rem;
    }
  }
</style>

<script>
  import gsap from "gsap";

  const MQ = "(min-width: 768px)";
  let headerCleanup: AbortController | null = null;

  function initPill(signal: AbortSignal) {
    const nav = document.getElementById("main-nav");
    const pill = document.getElementById("nav-pill");
    if (!nav || !pill || !window.matchMedia(MQ).matches) return;

    const links = Array.from(nav.querySelectorAll<HTMLElement>("[data-pill-link]"));
    const active = nav.querySelector<HTMLElement>(".nav-link.active");
    let clicking = false;

    function movePill(el: HTMLElement, animate = true) {
      const navRect = nav!.getBoundingClientRect();
      const elRect = el.getBoundingClientRect();
      const x = elRect.left - navRect.left;
      const w = elRect.width;

      if (animate) {
        gsap.to(pill, { x, width: w, opacity: 1, duration: 0.3, ease: "power3.out" });
      } else {
        gsap.set(pill, { x, width: w, opacity: 1 });
      }
    }

    function returnToActive() {
      if (clicking) return;
      if (active) {
        movePill(active);
      } else {
        gsap.to(pill, { opacity: 0, duration: 0.2 });
      }
    }

    if (active) movePill(active, false);

    links.forEach((link) => {
      link.addEventListener(
        "mouseenter",
        () => {
          if (!clicking) movePill(link);
        },
        { signal },
      );

      link.addEventListener("mouseleave", returnToActive, { signal });

      link.addEventListener(
        "mousedown",
        () => {
          clicking = true;
          movePill(link);
        },
        { signal },
      );

      link.addEventListener(
        "click",
        () => {
          setTimeout(() => {
            clicking = false;
          }, 600);
        },
        { signal },
      );
    });
  }

  function setHamburgerIcon(
    top: Element | null,
    mid: Element | null,
    bot: Element | null,
    isOpen: boolean,
  ) {
    if (!top || !mid || !bot) return;
    const dur = 0.32;
    const ease = "power3.inOut";
    if (isOpen) {
      gsap.to(top, { y: 5, rotation: 45, transformOrigin: "center", duration: dur, ease });
      gsap.to(mid, { opacity: 0, scaleX: 0, duration: dur * 0.45, ease });
      gsap.to(bot, { y: -5, rotation: -45, transformOrigin: "center", duration: dur, ease });
    } else {
      gsap.to(top, { y: 0, rotation: 0, duration: dur, ease });
      gsap.to(mid, { opacity: 1, scaleX: 1, duration: dur * 0.55, ease, delay: 0.06 });
      gsap.to(bot, { y: 0, rotation: 0, duration: dur, ease });
    }
  }

  function initMobileNav(signal: AbortSignal) {
    const header = document.querySelector<HTMLElement>("[data-header-root]");
    const toggle = document.getElementById("nav-toggle");
    const nav = document.getElementById("main-nav");
    const backdrop = document.getElementById("nav-backdrop");
    if (!header || !toggle || !nav || !backdrop) return;

    const lineTop = toggle.querySelector(".nav-toggle__line--top");
    const lineMid = toggle.querySelector(".nav-toggle__line--mid");
    const lineBot = toggle.querySelector(".nav-toggle__line--bot");
    const linkEls = nav.querySelectorAll<HTMLElement>(".nav-link");

    let open = false;
    let menuTl: gsap.core.Timeline | null = null;

    const mq = window.matchMedia(MQ);

    function closeMenu() {
      if (!open || !header || !toggle) return;
      open = false;
      header.classList.remove("nav-open");
      toggle.setAttribute("aria-expanded", "false");
      menuTl?.kill();
      menuTl = null;

      const tl = gsap.timeline({
        onComplete: () => {
          document.body.style.overflow = "";
          gsap.set(nav, { clearProps: "transform,opacity,visibility,pointerEvents" });
          gsap.set(backdrop, { clearProps: "opacity,visibility,pointerEvents" });
          gsap.set(linkEls, { clearProps: "transform,opacity" });
        },
      });
      tl.to(
        linkEls,
        { y: 20, opacity: 0, duration: 0.2, stagger: { each: 0.035, from: "end" }, ease: "power2.in" },
        0,
      );
      tl.to(nav, { y: "-6%", autoAlpha: 0, duration: 0.32, ease: "power3.in" }, 0.04);
      tl.to(backdrop, { autoAlpha: 0, duration: 0.28, ease: "power2.in" }, 0);
      setHamburgerIcon(lineTop, lineMid, lineBot, false);
    }

    function openMenu() {
      if (open || mq.matches || !header || !toggle) return;
      open = true;
      header.classList.add("nav-open");
      toggle.setAttribute("aria-expanded", "true");
      menuTl?.kill();
      document.body.style.overflow = "hidden";

      gsap.set(nav, { y: "-10%", autoAlpha: 0 });
      gsap.set(backdrop, { autoAlpha: 0 });
      gsap.set(linkEls, { y: 32, opacity: 0 });

      menuTl = gsap.timeline();
      menuTl.to(backdrop, { autoAlpha: 1, duration: 0.34, ease: "power2.out" }, 0);
      menuTl.to(nav, { y: "0%", autoAlpha: 1, duration: 0.52, ease: "expo.out" }, 0.05);
      menuTl.to(
        linkEls,
        { y: 0, opacity: 1, duration: 0.42, stagger: 0.065, ease: "back.out(1.2)" },
        "-=0.36",
      );
      setHamburgerIcon(lineTop, lineMid, lineBot, true);
    }

    function onToggleClick() {
      if (mq.matches) return;
      if (open) closeMenu();
      else openMenu();
    }

    toggle.addEventListener("click", onToggleClick, { signal });
    backdrop.addEventListener("click", closeMenu, { signal });

    const onMq = (e: MediaQueryListEvent) => {
      if (e.matches) {
        closeMenu();
        gsap.set([lineTop, lineMid, lineBot], { clearProps: "transform,opacity" });
      }
    };
    mq.addEventListener("change", onMq, { signal });

    /* Ne zatvaraj meni sinhrono na klik — može da ometa navigaciju; zatvori u sledećem frejmu */
    linkEls.forEach((a) => {
      a.addEventListener(
        "click",
        () => {
          if (!mq.matches) requestAnimationFrame(() => closeMenu());
        },
        { signal },
      );
    });

    document.addEventListener(
      "keydown",
      (e) => {
        if (e.key === "Escape" && open) closeMenu();
      },
      { signal },
    );
  }

  function initHeader() {
    headerCleanup?.abort();
    headerCleanup = new AbortController();
    const { signal } = headerCleanup;

    initMobileNav(signal);
    initPill(signal);
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);

  /* Ponovo veži pill / mobile posle rotacije uređaja (signal iz initHeader ne pokriva ovo) */
  let mqResizeBound = false;
  if (!mqResizeBound) {
    mqResizeBound = true;
    window.matchMedia(MQ).addEventListener("change", () => initHeader());
  }
</script>
