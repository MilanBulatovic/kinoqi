---
import { galleryImageSrc } from "@/lib/galleryImageUrl";

interface Props {
  images: Array<{
    _key: string;
    src?: string | null;
    asset?: { url?: string } | null;
    alt?: string;
    caption?: string;
  }>;
  /** Jedinstven u okviru stranice — za GSAP samo unutar ove galerije */
  instanceId: string;
}

const { images: rawImages, instanceId } = Astro.props;

const images = rawImages.filter((img) => galleryImageSrc(img));
const count = images.length;
const gridClass =
  count === 1 ? "gallery-grid--one"
  : count === 2 ? "gallery-grid--two"
  : "gallery-grid--many";

const rootId = `gallery-${instanceId.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
---

{
  count > 0 && (
    <div id={rootId} class="section gallery-section">
      <div class:list={["gallery-grid", gridClass]}>
        {images.map((image) => {
          const src = galleryImageSrc(image);
          if (!src) return null;
          return (
            <figure class="gallery-item">
              <img src={src} alt={image.alt ?? ""} loading="lazy" />
              {image.caption && <figcaption>{image.caption}</figcaption>}
            </figure>
          );
        })}
      </div>
    </div>
  )
}

<style>
  .section { margin: 0; }

  .gallery-grid {
    display: grid;
    gap: 1rem;
  }

  .gallery-grid--one {
    grid-template-columns: 1fr;
  }

  .gallery-grid--two {
    grid-template-columns: 1fr 1fr;
  }

  .gallery-grid--many {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }

  @media (max-width: 639px) {
    /* Tačno 2 slike: na mobilnom jedna kolona */
    .gallery-grid--two {
      grid-template-columns: 1fr;
    }

    .gallery-grid--two .gallery-item img {
      height: 260px;
    }

    /* 3+ slike: dve kolone */
    .gallery-grid--many {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
    }

    .gallery-grid--many .gallery-item img {
      height: 140px;
    }
  }

  .gallery-item {
    margin: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    background: #e5e7eb;
  }

  .gallery-item img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .gallery-grid--one .gallery-item img {
    height: 480px;
  }

  .gallery-grid--two .gallery-item img {
    height: 360px;
  }

  .gallery-item img:hover { transform: scale(1.03); }

  .gallery-item figcaption {
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
  }
</style>

<script lang="ts" define:vars={{ galleryRootId: rootId }}>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryScroll(rootId) {
    const root = document.getElementById(rootId);
    if (!root) return;

    const items = root.querySelectorAll(".gallery-item");
    items.forEach((item, i) => {
      const delay = (i % 3) * 0.12;

      ScrollTrigger.create({
        trigger: item,
        start: "top 92%",
        once: true,
        onEnter: () => {
          gsap.from(item, {
            opacity: 0,
            y: 32,
            scale: 0.98,
            duration: 0.75,
            ease: "power2.out",
            delay,
          });
        },
      });
    });

    root.querySelectorAll("img").forEach((img) => {
      if (img.complete) return;
      img.addEventListener("load", () => ScrollTrigger.refresh(), { once: true });
    });

    requestAnimationFrame(() => ScrollTrigger.refresh());
  }

  initGalleryScroll(galleryRootId);
</script>
