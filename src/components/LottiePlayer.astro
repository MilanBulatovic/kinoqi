---
interface Props {
  src: string;
  loop?: boolean;
  autoplay?: boolean;
  /** Kada se reprodukcija pomeri za N sekundi (npr. 1); radi uz autoplay. */
  playDelaySec?: number;
  speed?: number;
  width?: string;
  height?: string;
  class?: string;
  id?: string;
}

const {
  src,
  loop = true,
  autoplay = true,
  playDelaySec = 0,
  speed = 1,
  width = "100%",
  height = "100%",
  class: className = "",
  id,
} = Astro.props;

const uid = id ?? `lottie-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  id={uid}
  class:list={["lottie-player", className]}
  style={`width:${width}; height:${height};`}
  data-src={src}
  data-loop={String(loop)}
  data-autoplay={String(autoplay)}
  data-speed={String(speed)}
  data-play-delay-sec={String(playDelaySec)}
  aria-hidden="true"
></div>

<script>
  function mountDotLottie(el: HTMLElement) {
    if (el.dataset.initialized) return;
    el.dataset.initialized = "true";

    void import("@lottiefiles/dotlottie-web").then((mod) => {
      const delaySec = Math.max(0, parseFloat(el.dataset.playDelaySec ?? "0"));
      const wantAutoplay = el.dataset.autoplay === "true";
      const useDelayedStart = wantAutoplay && delaySec > 0;

      const instance = new mod.DotLottie({
        canvas: (() => {
          const canvas = document.createElement("canvas");
          canvas.style.width = "100%";
          canvas.style.height = "100%";
          el.appendChild(canvas);
          return canvas;
        })(),
        src: el.dataset.src!,
        loop: el.dataset.loop === "true",
        autoplay: useDelayedStart ? false : wantAutoplay,
        speed: parseFloat(el.dataset.speed ?? "1"),
      });
      if (useDelayedStart) {
        window.setTimeout(() => {
          instance.play();
        }, Math.round(delaySec * 1000));
      }
    });
  }

  document.querySelectorAll<HTMLElement>(".lottie-player").forEach((el) => {
    mountDotLottie(el);
  });
</script>

<style>
  .lottie-player {
    display: block;
    overflow: hidden;
  }

  .lottie-player canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
