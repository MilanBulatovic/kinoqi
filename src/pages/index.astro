---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LottiePlayer from "@/components/LottiePlayer.astro";

const letters = "kinoqi".split("");
---

<!-- ── Intro overlay ──────────────────────────────────────── -->
<div id="intro" aria-modal="true" role="dialog" aria-label="Intro">
  <div class="intro__video-wrap">
    <video
      class="intro__video"
      src="/video1.mp4"
      preload="auto"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <div class="intro__video-overlay"></div>
  </div>
  <div class="intro__noise"></div>

  <div class="intro__bottom">
    <button id="intro-enter" class="intro__enter" aria-label="Uđi na stranicu">
      <span class="intro__enter-text">enter</span>
    </button>
    <div class="intro__lottie">
      <LottiePlayer src="/Rocket Lunch.lottie" width="200px" height="200px" />
    </div>
  </div>
</div>

<!-- ── Actual page (hidden until intro exits) ────────────── -->
<div id="page-wrap" style="opacity:0; visibility:hidden;">
  <BaseLayout title="Kinoqi" description="Blog pokretan Astro-om i Sanity CMS-om" currentPath="/">
    <section class="banner" aria-label="Kinoqi banner">
      <video
        class="banner__video"
        src="/video3.mp4"
        preload="auto"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
      <div class="banner__overlay"></div>
      <h1 class="banner__title" aria-label="kinoqi">
        {letters.map((letter, i) => (
          <span class="banner__letter" data-index={i}>{letter}</span>
        ))}
      </h1>
      <div class="banner__scroll-hint">
        <span class="banner__scroll-line"></span>
      </div>
      <button class="banner__footer-trigger" id="footer-trigger" aria-label="Otvori footer">
        © 2026 Kinoqi
      </button>
    </section>
  </BaseLayout>
</div>

<style is:global>
  /* ── Reset body overflow while intro is active ──────────── */
  body.intro-active {
    overflow: hidden;
  }

  /* ── Intro overlay ──────────────────────────────────────── */
  #intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3.5rem;
    overflow: hidden;
  }

  .intro__video-wrap {
    position: absolute;
    inset: 0;
    will-change: transform;
    overflow: hidden;
  }

  .intro__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .intro__video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(10, 6, 30, 0.20) 50%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  /* film-grain texture via SVG noise */
  .intro__noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
    animation: grainShift 0.4s steps(1) infinite;
  }

  @keyframes grainShift {
    0%   { background-position: 0 0; }
    25%  { background-position: -30px 20px; }
    50%  { background-position: 15px -10px; }
    75%  { background-position: -20px -25px; }
    100% { background-position: 10px 30px; }
  }

  /* ── Bottom group (button + lottie) ────────────────────── */
  .intro__bottom {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    opacity: 0;
    animation: lottieFadeIn 0.8s ease-out 0.8s forwards;
  }

  @keyframes lottieFadeIn {
    from { opacity: 0; transform: translateX(-50%) translateY(16px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Enter button ───────────────────────────────────────── */
  .intro__enter {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 1;
    outline: none;
  }

  .intro__enter-text {
    display: block;
    font-family: "Kablammo", serif;
    font-size: 52px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    background: var(--logo-gradient);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 4s linear infinite;
  }

  @keyframes gradientShift {
    to { background-position: 200% center; }
  }

  @media (max-width: 640px) {
    .intro__enter-text {
      font-size: 32px;
      letter-spacing: 0.06em;
    }

    .intro__bottom {
      bottom: 1rem;
    }
  }

  /* ── Intro lottie ───────────────────────────────────────── */
  .intro__lottie {
    line-height: 0;
  }

  @media (max-width: 640px) {
    .intro__lottie :global(.lottie-player) {
      width: 140px !important;
      height: 140px !important;
    }
  }

  /* ── Page wrapper ───────────────────────────────────────── */
  #page-wrap {
    will-change: opacity;
  }

  /* ── Banner (same as before) ────────────────────────────── */
  .banner {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  .banner__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(10, 6, 30, 0.55) 50%,
      rgba(0, 0, 0, 0.72) 100%
    );
  }

  .banner__title {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 0.04em;
    font-family: "Kablammo", serif;
    font-size: clamp(5rem, 20vw, 18rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: lowercase;
    color: transparent;
    user-select: none;
  }

  .banner__letter {
    display: inline-block;
    will-change: transform, opacity, filter;
    opacity: 0;
    transform: translateY(60px) skewY(6deg);
    filter: blur(16px);
    background: linear-gradient(
      120deg,
      #e8c99a 0%,
      #c97d4e 30%,
      #a85432 55%,
      #c8903a 75%,
      #e2b97a 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .banner__scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
  }

  .banner__scroll-line {
    display: block;
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.8), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.15); }
  }

  /* ── Footer trigger ─────────────────────────────────────── */
  .banner__footer-trigger {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    z-index: 2;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.75rem;
    font-family: inherit;
    letter-spacing: 0.06em;
    cursor: pointer;
    padding: 0.25rem 0;
    opacity: 0;
    transition: color 0.2s;
  }

  .banner__footer-trigger::after {
    content: "";
    display: block;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    transition: width 0.25s ease;
    margin-top: 3px;
  }

  .banner__footer-trigger:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .banner__footer-trigger:hover::after {
    width: 100%;
  }

  /* ── Footer hidden by default on homepage ───────────────── */
  body.homepage #site-footer {
    overflow: hidden;
    height: 0;
    opacity: 0;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollToPlugin from "gsap/ScrollToPlugin";
  gsap.registerPlugin(ScrollToPlugin);

  function initDistortion(pageWrap: HTMLElement, letters: NodeListOf<HTMLElement>) {
    const titleEl = pageWrap.querySelector<HTMLElement>(".banner__title");
    if (!titleEl) return;
    titleEl.addEventListener("mousemove", (e: MouseEvent) => {
      letters.forEach((letter) => {
        const rect  = letter.getBoundingClientRect();
        const dx    = e.clientX - (rect.left + rect.width / 2);
        const dy    = e.clientY - (rect.top + rect.height / 2);
        const force = Math.max(0, 1 - Math.sqrt(dx * dx + dy * dy) / 180);
        gsap.to(letter, { skewX: dx * force * 0.08, skewY: dy * force * 0.03, x: dx * force * 0.18, y: dy * force * 0.12, scale: 1 + force * 0.12, duration: 0.3, ease: "power2.out", overwrite: "auto" });
      });
    });
    titleEl.addEventListener("mouseleave", () => {
      letters.forEach((l) => gsap.to(l, { skewX: 0, skewY: 0, x: 0, scale: 1, duration: 0.6, ease: "elastic.out(1, 0.4)", overwrite: "auto" }));
    });
  }

  function initFooterToggle(footer: HTMLElement, trigger: HTMLElement) {
    const items = footer.querySelectorAll<HTMLElement>(".footer-anim");
    gsap.set(items, { opacity: 0, y: 40 });
    let open = false, busy = false;
    trigger.addEventListener("click", () => {
      if (busy) return;
      busy = true;
      if (!open) {
        open = true;
        trigger.textContent = "✕ zatvori";
        const tl = gsap.timeline({ onComplete: () => { busy = false; } });
        tl.to(footer, { height: "auto", duration: 0.7, ease: "expo.out" });
        tl.to(footer, { opacity: 1, duration: 0.4, ease: "power2.out" }, "<0.2");
        tl.to(items, { opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: "power3.out", onStart: () => { footer.style.overflow = ""; } }, "<0.1");
        tl.to(window, { scrollTo: footer, duration: 0.7, ease: "power2.inOut" }, "<");
      } else {
        open = false;
        trigger.textContent = "© 2026 Kinoqi";
        footer.style.overflow = "hidden";
        const tl = gsap.timeline({ onComplete: () => { busy = false; } });
        tl.to(window, { scrollTo: 0, duration: 0.55, ease: "power2.inOut" });
        tl.to(items, { opacity: 0, y: 30, duration: 0.4, stagger: { each: 0.08, from: "end" }, ease: "power2.in" }, "<0.1");
        tl.to(footer, { opacity: 0, duration: 0.3, ease: "power1.in" }, "<0.2");
        tl.to(footer, { height: 0, duration: 0.5, ease: "expo.in" }, "<0.1");
      }
    });
  }

  function initFloatLoop(letters: NodeListOf<HTMLElement>, delay = 0) {
    letters.forEach((el, i) => {
      gsap.to(el, { y: gsap.utils.random(-8, 8), duration: gsap.utils.random(2.5, 4), ease: "sine.inOut", yoyo: true, repeat: -1, delay: delay + i * 0.12 });
    });
  }

  function initPage() {
    const introEl    = document.getElementById("intro");
    if (!introEl) return;

    const enterBtn       = introEl.querySelector<HTMLButtonElement>("#intro-enter")!;
    const pageWrap       = document.getElementById("page-wrap")!;
    const bannerLetters  = pageWrap.querySelectorAll<HTMLElement>(".banner__letter");
    const scrollHint     = pageWrap.querySelector<HTMLElement>(".banner__scroll-hint")!;
    const introVideoWrap = introEl.querySelector<HTMLElement>(".intro__video-wrap")!;
    const footer         = document.getElementById("site-footer")!;
    const footerTrigger  = document.getElementById("footer-trigger")!;

    document.body.classList.add("homepage");
    gsap.set(footer, { height: 0, opacity: 0, overflow: "hidden" });

    /* ── Show intro ──────────────────────────────────────── */
    document.body.classList.add("intro-active");
    gsap.fromTo(introVideoWrap, { scale: 1.08 }, { scale: 1, duration: 2.4, ease: "power2.out" });
    gsap.set(pageWrap, { visibility: "visible", opacity: 0 });

    enterBtn.addEventListener("click", () => {
      enterBtn.disabled = true;
      const introLottie = introEl.querySelector<HTMLElement>(".intro__lottie")!;
      const tl = gsap.timeline({ defaults: { ease: "sine.inOut" } });

      gsap.set(enterBtn, { opacity: 0 });
      tl.to(introLottie, { y: -160, opacity: 0, filter: "blur(14px)", duration: 1.4, ease: "power2.inOut" });
      tl.to(introVideoWrap, { scale: 1.06, filter: "blur(8px)", duration: 1.0, ease: "power1.inOut" }, "<");
      tl.to(introEl,  { opacity: 0, duration: 1.1, ease: "power1.inOut" }, "-=0.6");
      tl.to(pageWrap, { opacity: 1, duration: 1.1, ease: "power1.inOut" }, "<");
      tl.call(() => {
        introEl.remove();
        document.body.classList.remove("intro-active");
      });
      tl.to(bannerLetters, { opacity: 1, y: 0, skewY: 0, filter: "blur(0px)", duration: 1.3, stagger: { each: 0.1, ease: "power2.inOut" }, ease: "expo.out" }, "-=0.5");
      tl.to(bannerLetters, { x: () => gsap.utils.random(-6, 6), filter: () => `blur(0px) hue-rotate(${gsap.utils.random(-40, 40)}deg)`, duration: 0.07, stagger: { each: 0.04, from: "random" }, yoyo: true, repeat: 3, ease: "none" }, "+=0.1");
      tl.to(bannerLetters, { x: 0, filter: "blur(0px) hue-rotate(0deg)", duration: 0.4, stagger: 0.03, ease: "power2.out" });
      tl.to(scrollHint, { opacity: 1, duration: 1.0, ease: "power1.out" }, "-=0.5");
      tl.to(footerTrigger, { opacity: 1, duration: 0.8, ease: "power1.out" }, "-=0.3");
      tl.call(() => {
        initFloatLoop(bannerLetters, 0);
        initDistortion(pageWrap, bannerLetters);
        initFooterToggle(footer, footerTrigger);
      });
    });
  }

  document.addEventListener("astro:page-load", initPage);
</script>
