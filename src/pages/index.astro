---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LottiePlayer from "@/components/LottiePlayer.astro";

const letters = "Welcome".split("");

const introVideoAttrs = { fetchpriority: "high" } as Record<string, string>;
---

<BaseLayout title="Kinoqi" description="Blog pokretan Astro-om i Sanity CMS-om" currentPath="/">
  <link slot="head" rel="preload" href="/video1.mp4" as="video" type="video/mp4" {...introVideoAttrs} />
  <link slot="head" rel="preload" href="/Rocket%20Lunch.lottie" as="fetch" />

  <div id="intro" slot="intro" aria-modal="true" role="dialog" aria-label="Intro">
    <div class="intro__video-wrap">
      <video
        class="intro__video"
        src="/video1.mp4"
        preload="auto"
        autoplay
        muted
        loop
        playsinline
        {...introVideoAttrs}
      ></video>
      <div class="intro__video-overlay"></div>
    </div>
    <div class="intro__noise"></div>

    <div class="intro__bottom">
      <button id="intro-enter" class="intro__enter" aria-label="Uđi na stranicu">
        <span class="intro__enter-text">enter</span>
      </button>
      <div class="intro__lottie">
        <LottiePlayer src="/Rocket Lunch.lottie" width="200px" height="200px" />
      </div>
    </div>
  </div>

  <div id="page-wrap" style="opacity:0; visibility:hidden;">
    <section class="banner" aria-label="Kinoqi banner">
      <video
        class="banner__video"
        data-src="/video3.mp4"
        preload="none"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
      <div class="banner__overlay"></div>
      <h1 class="banner__title" aria-label="kinoqi">
        {letters.map((letter, i) => (
          <span class="banner__letter" data-index={i}>{letter}</span>
        ))}
      </h1>
      <div class="banner__scroll-hint">
        <span class="banner__scroll-line"></span>
      </div>
      <button class="banner__footer-trigger" id="footer-trigger" aria-label="Otvori footer">
        © 2026 Kinoqi
      </button>
    </section>
  </div>

  <script>
    import "@/scripts/homeIntro";
  </script>
</BaseLayout>

<style is:global>
  /* ── Reset body overflow while intro is active ──────────── */
  body.intro-active {
    overflow: hidden;
  }

  /* ── Intro overlay ──────────────────────────────────────── */
  #intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3.5rem;
    overflow: hidden;
    /* Prvi paint odmah (pre prvog frejma videa) — poboljšava FCP */
    background: #07040f;
  }

  .intro__video-wrap {
    position: absolute;
    inset: 0;
    will-change: transform;
    overflow: hidden;
  }

  .intro__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .intro__video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(10, 6, 30, 0.20) 50%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  /* film-grain texture via SVG noise */
  .intro__noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px;
    animation: grainShift 0.4s steps(1) infinite;
  }

  @keyframes grainShift {
    0%   { background-position: 0 0; }
    25%  { background-position: -30px 20px; }
    50%  { background-position: 15px -10px; }
    75%  { background-position: -20px -25px; }
    100% { background-position: 10px 30px; }
  }

  /* ── Bottom group (button + lottie) ────────────────────── */
  .intro__bottom {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    opacity: 0;
    /* Kratko kašnjenje da ne takmiči učitavanje videa; ranije nego 0.8s + 0.8s */
    animation: lottieFadeIn 0.45s ease-out 0.12s forwards;
  }

  @keyframes lottieFadeIn {
    from { opacity: 0; transform: translateX(-50%) translateY(12px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ── Enter button ───────────────────────────────────────── */
  .intro__enter {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 1;
    outline: none;
  }

  .intro__enter-text {
    display: block;
    font-family: "Kablammo", serif;
    font-size: 52px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    background: var(--logo-gradient);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 4s linear infinite;
  }

  @keyframes gradientShift {
    to { background-position: 200% center; }
  }

  @media (max-width: 640px) {
    .intro__enter-text {
      font-size: 32px;
      letter-spacing: 0.06em;
    }

    .intro__bottom {
      bottom: 1rem;
    }
  }

  /* ── Intro lottie ───────────────────────────────────────── */
  .intro__lottie {
    line-height: 0;
  }

  @media (max-width: 640px) {
    .intro__lottie :global(.lottie-player) {
      width: 140px !important;
      height: 140px !important;
    }
  }

  /* ── Page wrapper ───────────────────────────────────────── */
  #page-wrap {
    will-change: opacity;
  }

  /* ── Banner (same as before) ────────────────────────────── */
  .banner {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  .banner__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(10, 6, 30, 0.55) 50%,
      rgba(0, 0, 0, 0.72) 100%
    );
  }

  .banner__title {
    position: relative;
    z-index: 2;
    display: flex;
    gap: 0.04em;
    font-family: "Kablammo", serif;
    font-size: clamp(5rem, 20vw, 18rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: lowercase;
    color: transparent;
    user-select: none;
  }

  .banner__letter {
    display: inline-block;
    will-change: transform, opacity, filter;
    opacity: 0;
    transform: translateY(60px) skewY(6deg);
    filter: blur(16px);
    background: linear-gradient(
      120deg,
      #e8c99a 0%,
      #c97d4e 30%,
      #a85432 55%,
      #c8903a 75%,
      #e2b97a 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .banner__scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
  }

  .banner__scroll-line {
    display: block;
    width: 1px;
    height: 64px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.8), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.15); }
  }

  /* ── Footer trigger ─────────────────────────────────────── */
  .banner__footer-trigger {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    z-index: 2;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.75rem;
    font-family: inherit;
    letter-spacing: 0.06em;
    cursor: pointer;
    padding: 0.25rem 0;
    opacity: 0;
    transition: color 0.2s;
  }

  .banner__footer-trigger::after {
    content: "";
    display: block;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    transition: width 0.25s ease;
    margin-top: 3px;
  }

  .banner__footer-trigger:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .banner__footer-trigger:hover::after {
    width: 100%;
  }

  /* ── Footer: samo sužena visina — nema opacity:0 da ne „bleše“ telo (svetlo) ispod */
  body.homepage #site-footer {
    overflow: hidden;
    height: 0;
  }
</style>
