---
import { ViewTransitions } from "astro:transitions";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  currentPath?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Kinoqi - Astro | Sanity",
  image = "/logo3.png",
  currentPath,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(currentPath ?? "/", Astro.site ?? Astro.url.origin);
const fullTitle = `${title} – Kinoqi`;
---

<!doctype html>
<html lang="sr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Stranice mogu ovde ranije da ubace preload (video / lottie) -->
    <slot name="head" />

    <!-- Primary -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:locale"      content="sr_RS" />
    <meta property="og:site_name"   content="Kinoqi" />

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />

    <!-- Fonts: ne blokiraju prvi paint (FOUC kratko moguće) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Kablammo&display=swap"
      {...({ media: "print", onload: "this.media='all'" } as Record<string, string>)}
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Kablammo&display=swap"
      />
    </noscript>

    <script>
      import "@/scripts/scrollTriggerViewTransitions";
    </script>
  </head>
  <body>
    <slot name="intro" />
    <Header currentPath={currentPath} />
    <slot />
    <Footer currentPath={currentPath} />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #4f46e5;
    --color-text: #111827;
    --color-muted: #6b7280;
    --color-bg: #f9fafb;
    --header-height: 72px;
    --logo-gradient: linear-gradient(120deg, #e8c99a 0%, #c97d4e 40%, #a85432 65%, #e2b97a 100%);
    --color-dark: #051424;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  body {
    font-family: "Syne", system-ui, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
  }

  body:not(.homepage) main {
    padding-top: var(--header-height);
  }
</style>
